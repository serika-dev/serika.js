{
  "name": "@serikadev/serika.js",
  "version": "1.0.1",
  "description": "A highly optimized TypeScript library for the SerikaCord API — Discord v10 compatible bot API + SerikaCord client API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "serikacord",
    "serika",
    "discord",
    "bot",
    "api",
    "wrapper"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0"
  },
  "peerDependencies": {
    "ws": "^8.18.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
